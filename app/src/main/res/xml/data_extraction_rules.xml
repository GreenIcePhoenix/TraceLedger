<?xml version="1.0" encoding="utf-8"?>
<!--
    TraceLedger is a privacy-first, local-only app.
    No financial data should ever leave the device via automatic cloud backup.
    Users who want to transfer data between devices should use
    Settings → Export Data (JSON) and import on the new device.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="file" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="file" path="." />
    </device-transfer>
</data-extraction-rules>